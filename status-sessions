#!/usr/bin/env bash
# tau status-right sessions — clickable project session list for tmux status bar.
# Filters sessions to those matching a ~/Developer directory, highlights the
# current session with a blue badge, and makes inactive sessions clickable.
set -euo pipefail

current=$(tmux display-message -p '#{session_name}')
idx=0

while IFS= read -r session; do
  # Only show sessions that correspond to a ~/Developer directory
  [ -d "$HOME/Developer/$session" ] || continue
  idx=$((idx + 1))
  if [ "$session" = "$current" ]; then
    # Active session — blue badge with powerline-style transitions
    printf '#[fg=#1e2030,bg=#82aaff]#[fg=#1b1d2b,bg=#82aaff,bold] %d %s #[fg=#82aaff,bg=#1e2030]' "$idx" "$session"
  else
    # Inactive session — subtle, clickable to switch
    printf '#[fg=#828bb8,bg=#1e2030,click=switch-client -t %s] %d %s ' "$session" "$idx" "$session"
  fi
done < <(tmux list-sessions -F '#{session_name}')
