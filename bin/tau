#!/usr/bin/env bash
set -euo pipefail

# tau — launch or attach to the isolated tau tmux server

# Guard: no nested tmux sessions
if [ -n "${TMUX:-}" ]; then
    echo "tau: already inside tmux. Run from a plain terminal." >&2
    exit 1
fi

export TAU_ROOT
_self="$(readlink -f "$0")"
TAU_ROOT="$(cd "$(dirname "$_self")/.." && pwd)"

TAU_SOCKET="tau"
TAU_CONFIG="$TAU_ROOT/config/tmux.conf"

if tmux -L "$TAU_SOCKET" has-session 2>/dev/null; then
    exec tmux -L "$TAU_SOCKET" attach
else
    exec tmux -L "$TAU_SOCKET" -f "$TAU_CONFIG" new-session -s scratch
fi
