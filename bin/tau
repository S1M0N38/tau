#!/usr/bin/env bash
set -euo pipefail

# tau — launch or attach to the isolated tau tmux server

# Guard: no nested tmux sessions
if [ -n "${TMUX:-}" ]; then
    echo "tau: already inside tmux. Run from a plain terminal." >&2
    exit 1
fi

export TAU_ROOT
_self="$(readlink -f "$0")"
TAU_ROOT="$(cd "$(dirname "$_self")/.." && pwd)"

# --- Required environment variables ---

if [ -z "${TAU_PROJECT_DIR:-}" ]; then
    echo "tau: TAU_PROJECT_DIR is not set. Set it to your projects directory." >&2
    echo "     Example: export TAU_PROJECT_DIR=~/Developer" >&2
    exit 1
fi

# Expand ~ and verify the directory exists
TAU_PROJECT_DIR="$(cd "$TAU_PROJECT_DIR" 2>/dev/null && pwd)" || {
    echo "tau: TAU_PROJECT_DIR='$TAU_PROJECT_DIR' does not exist or is not a directory." >&2
    exit 1
}
export TAU_PROJECT_DIR

# Optional — defaults to empty; tmux keybindings will show a notification if unset
export TAU_EDITOR_CMD="${TAU_EDITOR_CMD:-}"
export TAU_GIT_CMD="${TAU_GIT_CMD:-}"

# Optional — defaults to pi (the coding agent command to spawn)
export TAU_AGENT_CMD="${TAU_AGENT_CMD:-pi}"

TAU_SOCKET="tau"
TAU_CONFIG="$TAU_ROOT/config/tmux.conf"

# Pass env vars into the tmux server environment so run-shell scripts can see them
start_tmux() {
    if tmux -L "$TAU_SOCKET" has-session 2>/dev/null; then
        exec tmux -L "$TAU_SOCKET" attach
    else
        exec tmux -L "$TAU_SOCKET" -f "$TAU_CONFIG" new-session -s scratch \
            -e TAU_ROOT="$TAU_ROOT" \
            -e TAU_PROJECT_DIR="$TAU_PROJECT_DIR" \
            -e TAU_EDITOR_CMD="$TAU_EDITOR_CMD" \
            -e TAU_GIT_CMD="$TAU_GIT_CMD" \
            -e TAU_AGENT_CMD="$TAU_AGENT_CMD"
    fi
}

start_tmux
