root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.lua]
indent_style = space
indent_size = 2
continuation_indent = 2
quote_style = double
max_line_length = 120
call_parentheses = true

[*.sh]
indent_style = space
indent_size = 2

[bin/tau]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.conf]
indent_style = space
indent_size = 2
