#!/usr/bin/env bash
# tau sessionizer — pick a repo in ~/Developer, create or switch tmux session.
set -euo pipefail

selected=$(find ~/Developer -mindepth 1 -maxdepth 1 -type d -exec basename {} \; \
  | fzf --reverse --height=~40% --no-mouse --prompt="session> ") || exit 0

name=$(echo "$selected" | tr ' .:' '-' | tr '[:upper:]' '[:lower:]')
path="$HOME/Developer/$selected"

if ! tmux has-session -t="$name" 2>/dev/null; then
  tmux new-session -d -s "$name" -c "$path"
  tmux display-message "Created $name"
fi

tmux switch-client -t "$name"
