#!/usr/bin/env bash
set -euo pipefail

# tau-popup-git — toggle git popup (Cmd+G)

source "${TAU_ROOT}/lib/common.sh"

if [[ -z "${TAU_GIT_CMD:-}" ]]; then
    tmux -L "$TAU_SOCKET" display-message "TAU_GIT_CMD is not set. Configure it before using Cmd+G."
    exit 0
fi

"$TAU_ROOT/scripts/tau-toggle-popup" git "$TAU_GIT_CMD" 90% 90%
