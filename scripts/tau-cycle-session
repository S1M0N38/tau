#!/usr/bin/env bash
# tau-cycle-session — cycle sessions in @sort-index order
# Usage: tau-cycle-session <next|prev>
set -euo pipefail

source "${TAU_ROOT}/lib/common.sh"

direction="${1:-next}"
current="$(tau_current_session)"

# Collect session names sorted by @sort-index into a temp file.
tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT

tau_list_sessions | cut -d'|' -f2 > "$tmpfile"

# Count sessions
count=$(wc -l < "$tmpfile" | tr -d ' ')
[ "$count" -eq 0 ] && exit 0

# Find current session's position
found=$(awk -v cur="$current" '$0 == cur { print NR; exit }' "$tmpfile")

# If current session is not found, go to the first one
if [ -z "$found" ]; then
    target=1
elif [ "$direction" = "next" ]; then
    target=$(( (found % count) + 1 ))
else
    if [ "$found" -eq 1 ]; then
        target=$count
    else
        target=$((found - 1))
    fi
fi

# Switch to the target session
target_name=$(sed -n "${target}p" "$tmpfile")
tmux -L "$TAU_SOCKET" switch-client -t "$target_name"
