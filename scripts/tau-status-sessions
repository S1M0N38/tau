#!/usr/bin/env bash
# tau-status-sessions — clickable session list for status-right
# Usage: tau-status-sessions <current-session-name>
set -euo pipefail

source "${TAU_ROOT}/lib/common.sh"

current="$1"

# Sort by @sort-index (creation-order fallback), then display.
tau_list_sessions | {
idx=0
while IFS='|' read -r _ name; do
    idx=$((idx + 1))
    if [ "$name" = "$current" ]; then
        printf '#[fg=#1e2030,bg=#82aaff]#[fg=#1b1d2b,bg=#82aaff,bold] %d %s #[fg=#82aaff,bg=#1e2030]' "$idx" "$name"
    else
        printf '#[fg=#828bb8,bg=#1e2030,click=switch-client -t %s] %d %s ' "$name" "$idx" "$name"
    fi
done
}
