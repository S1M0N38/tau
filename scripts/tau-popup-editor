#!/usr/bin/env bash
set -euo pipefail

# tau-popup-editor — toggle editor popup (Cmd+E)

source "${TAU_ROOT}/lib/common.sh"

if [[ -z "${TAU_EDITOR_CMD:-}" ]]; then
    tmux -L "$TAU_SOCKET" display-message "TAU_EDITOR_CMD is not set. Configure it before using Cmd+E."
    exit 0
fi

"$TAU_ROOT/scripts/tau-toggle-popup" editor "$TAU_EDITOR_CMD" 90% 90%
