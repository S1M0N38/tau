#!/usr/bin/env bash
# tau-spawn-pi â€” spawn pi pane in grid layout (pure bash)
# Grid: side-by-side up to max_cols, then new rows below. Min 80 cols/pane.

set -uo pipefail

source "${TAU_ROOT}/lib/common.sh"

MIN_WIDTH=80
MIN_HEIGHT=10

current_pane=$(tmux -L "$TAU_SOCKET" display-message -p '#{pane_id}')
current_cmd=$(tmux -L "$TAU_SOCKET" display-message -p '#{pane_current_command}')
# shellcheck disable=SC2221,SC2222
case "$current_cmd" in
  *bash*|*zsh*|*sh|fish|dash|ksh|csh|tcsh)
    tmux -L "$TAU_SOCKET" send-keys -t "$current_pane" pi Enter
    exit 0
    ;;
esac

window_width=$(tmux -L "$TAU_SOCKET" display-message -p '#{window_width}')
window_height=$(tmux -L "$TAU_SOCKET" display-message -p '#{window_height}')

max_cols=$((window_width / MIN_WIDTH))
[ "$max_cols" -lt 1 ] && max_cols=1

current_total=$(tmux -L "$TAU_SOCKET" list-panes -F '#{pane_id}' | wc -l | tr -d ' ')
total=$((current_total + 1))

cols=$max_cols
if [ "$total" -lt "$cols" ]; then
  cols=$total
fi
rows=$(( (total + cols - 1) / cols ))

pane_h=$(( (window_height - (rows - 1)) / rows ))
if [ "$pane_h" -lt "$MIN_HEIGHT" ]; then
  tmux -L "$TAU_SOCKET" display-message "âš  Not enough space to spawn another pane (height ${pane_h} rows < ${MIN_HEIGHT})"
  exit 1
fi

new_pane=$(tmux -L "$TAU_SOCKET" split-window -h -P -F '#{pane_id}' -c "#{pane_current_path}" "pi") || {
  tmux -L "$TAU_SOCKET" display-message "Failed to spawn pi pane (not enough space?)"
  exit 0
}


W=$window_width
H=$window_height

pane_w=$(( (W - (cols - 1)) / cols ))
pane_h=$(( (H - (rows - 1)) / rows ))

if [ "$rows" -eq 1 ] && [ "$cols" -eq 1 ]; then
    tree="${W}x${H},0,0,0"

elif [ "$rows" -eq 1 ]; then
    children=""
    x=0
    c=0
    while [ "$c" -lt "$cols" ]; do
        if [ "$c" -lt $((cols - 1)) ]; then
            w=$pane_w
        else
            w=$(( W - x ))
        fi
        cell="${w}x${H},${x},0,0"
        if [ -z "$children" ]; then
            children="$cell"
        else
            children="${children},${cell}"
        fi
        x=$(( x + w + 1 ))
        c=$(( c + 1 ))
    done
    tree="${W}x${H},0,0{${children}}"

else
    row_cells=""
    y=0
    idx=0
    r=0
    while [ "$r" -lt "$rows" ]; do
        remaining=$(( total - idx ))
        row_cols=$cols
        [ "$remaining" -lt "$row_cols" ] && row_cols=$remaining

        if [ "$r" -lt $((rows - 1)) ]; then
            h=$pane_h
        else
            h=$(( H - y ))
        fi

        if [ "$row_cols" -eq 1 ]; then
            cell="${W}x${h},0,${y},0"
            idx=$(( idx + 1 ))
        else
            children=""
            x=0
            c=0
            while [ "$c" -lt "$row_cols" ]; do
                if [ "$c" -lt $((row_cols - 1)) ]; then
                    w=$pane_w
                else
                    w=$(( W - x ))
                fi
                child="${w}x${h},${x},${y},0"
                if [ -z "$children" ]; then
                    children="$child"
                else
                    children="${children},${child}"
                fi
                x=$(( x + w + 1 ))
                c=$(( c + 1 ))
                idx=$(( idx + 1 ))
            done
            cell="${W}x${h},0,${y}{${children}}"
        fi

        if [ -z "$row_cells" ]; then
            row_cells="$cell"
        else
            row_cells="${row_cells},${cell}"
        fi

        y=$(( y + h + 1 ))
        r=$(( r + 1 ))
    done
    tree="${W}x${H},0,0[${row_cells}]"
fi

# Checksum: rotate-right-1-bit + byte value, lower 16 bits
csum=0
i=0
len=${#tree}
while [ "$i" -lt "$len" ]; do
    ch="${tree:$i:1}"
    ascii=$(printf '%d' "'$ch")
    csum=$(( (csum >> 1) | ((csum & 1) << 15) ))
    csum=$(( csum + ascii ))
    csum=$(( csum & 0xFFFF ))
    i=$(( i + 1 ))
done

checksum=$(printf '%04x' "$csum")

layout_string="${checksum},${tree}"

tmux -L "$TAU_SOCKET" select-layout "$layout_string" 2>/dev/null || {
  tmux -L "$TAU_SOCKET" display-message "Could not apply grid layout (pane spawned anyway)"
}

tmux -L "$TAU_SOCKET" select-pane -t "$new_pane"
