#!/usr/bin/env bash
# tau-swap-session — swap current session with adjacent, renumber all
# Usage: tau-swap-session <next|prev>
set -euo pipefail

source "${TAU_ROOT}/lib/common.sh"

direction="${1:-next}"
current="$(tau_current_session)"

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT

# Collect all sessions sorted by @sort-index
tau_list_sessions > "$tmpfile"

# Need at least 2 sessions to swap
count=$(wc -l < "$tmpfile" | tr -d ' ')
[ "$count" -lt 2 ] && exit 0

# Find current session's position in sorted list
found=$(awk -F'|' -v cur="$current" '$2 == cur { print NR; exit }' "$tmpfile")
[ -z "$found" ] && exit 0

# Calculate target position (clamp at boundaries)
if [ "$direction" = "next" ]; then
    target=$((found + 1))
else
    target=$((found - 1))
fi
[ "$target" -lt 1 ] && exit 0
[ "$target" -gt "$count" ] && exit 0

# Swap the two entries and reassign sequential sort-indices.
# awk reads all sessions, swaps the two positions, then outputs with clean
# sequential indices.
awk -F'|' -v found="$found" -v target="$target" 'BEGIN { OFS="|" }
{ names[NR] = $2 }
END {
    tmp = names[found]
    names[found] = names[target]
    names[target] = tmp
    for (i = 1; i <= NR; i++) print i, names[i]
}' "$tmpfile" | while IFS='|' read -r new_idx name; do
    tmux -L "$TAU_SOCKET" set-option -t "$name" @sort-index "$new_idx"
done

# Refresh status line to reflect the change
tmux -L "$TAU_SOCKET" refresh-client -S
