#!/usr/bin/env bash
# tau-session-closed — handle session destruction
# With detach-on-destroy off, tmux auto-switches to another session.
# This script kills the tau server if only hidden or no sessions remain.
set -euo pipefail

source "${TAU_ROOT}/lib/common.sh"

# tau_list_sessions already excludes @hidden sessions.
# If no visible sessions remain, kill the server.
remaining=$(tau_list_sessions | cut -d'|' -f2 || true)

if [ -z "$remaining" ]; then
    tmux -L "$TAU_SOCKET" kill-server
fi
